{
  "robot_name": "rovi",
  "ui": {
    "dark_theme": true,
    "stale_timeout_ms": 5000,
    "background": "#0B1220",
    "splash": { "path": "/rovi.bmp", "duration_ms": 3000 }
  },
  "layout": {
    "cols": 2,
    "rows": 3,
    "tiles": [
      { "id": "tile_voltage" },
      { "id": "tile_cpu" },
      { "id": "tile_hz" },
      { "id": "tile_sys" },
      { "id": "tile_hz" },
      { "id": "tile_sys" }
    ]
  },
  "gauges": [
    {
      "id": "voltage",
      "tile_id": "tile_voltage",
      "title": "Voltage",
      "min": 90,
      "max": 130,
      "min_label": "9V",
      "max_label": "13V",
      "accent": "green",
      "stages": [
        { "t": 126, "c": "green" },
        { "t": 111, "c": "green" },
        { "t": 110, "c": "amber" },
        { "t": 105, "c": "orange" },
        { "t": 90, "c": "red" }
      ]
    },
    {
      "id": "cpu",
      "tile_id": "tile_cpu",
      "title": "CPU",
      "min": 0,
      "max": 100,
      "min_label": "0%",
      "max_label": "100%",
      "accent": "amber"
    }
  ],
  "hz_lists": [
    {
      "id": "pipeline_hz",
      "tile_id": "tile_hz",
      "title": "Pipeline Hz",
      "rows": [
        { "id": "hz_depth", "label": "depth", "target": 15 },
        { "id": "hz_color", "label": "color", "target": 15 },
        { "id": "hz_slam", "label": "slam", "target": 30 },
        { "id": "hz_nav", "label": "nav", "target": 20 }
      ]
    },
    {
      "id": "raspi_sys",
      "tile_id": "tile_sys",
      "title": "Raspi System",
      "rows": [
        { "id": "mem_used", "label": "Mem", "target": 160, "polarity": "negative" },
        { "id": "wlan", "label": "WiFi", "type": "text" },
        { "id": "hz_driver", "label": "driver", "target": 10 },
        { "id": "hz_lidar", "label": "lidar", "target": 10 }
      ]
    }
  ]
}
